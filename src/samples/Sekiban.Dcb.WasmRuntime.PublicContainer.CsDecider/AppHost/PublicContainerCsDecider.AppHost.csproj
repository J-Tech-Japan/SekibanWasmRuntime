<Project Sdk="Aspire.AppHost.Sdk/13.2.0">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsAspireHost>true</IsAspireHost>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>PublicContainerCsDecider.AppHost</RootNamespace>
    <AssemblyName>PublicContainerCsDecider.AppHost</AssemblyName>
    <!-- Self-contained like an external consumer (versions pinned here, not via CPM). -->
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
  </PropertyGroup>

  <!--
    Public-consumer proof: this AppHost runs the PUBLIC runtime container image
    (AddContainer, never AddProject<...Host>) and a Postgres event DB through
    Aspire. The repo pins the Aspire 13.2.x line; an external consumer would use
    their own Aspire version.
  -->
  <ItemGroup>
    <PackageReference Include="Aspire.Hosting" Version="13.2.2" />
    <PackageReference Include="Aspire.Hosting.PostgreSQL" Version="13.2.2" />
    <!-- The published package is Sekiban.Dcb.WasmRuntime.Aspire; referenced as a
         project until the first NuGet publish. IsAspireProjectResource=false keeps
         the AppHost SDK from treating the library as an orchestrated project. -->
    <ProjectReference Include="../../../lib/Sekiban.Dcb.WasmRuntime.Aspire/Sekiban.Dcb.WasmRuntime.Aspire.csproj"
                      IsAspireProjectResource="false" />
  </ItemGroup>

</Project>
