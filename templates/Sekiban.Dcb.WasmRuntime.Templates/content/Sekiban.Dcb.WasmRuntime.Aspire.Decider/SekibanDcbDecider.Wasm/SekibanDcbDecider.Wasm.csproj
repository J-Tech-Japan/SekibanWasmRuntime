<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>wasi-wasm</RuntimeIdentifier>
    <OutputType>library</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <IlcTrimMetadata>false</IlcTrimMetadata>
    <InvariantGlobalization>true</InvariantGlobalization>
    <IsAotCompatible>true</IsAotCompatible>
    <WASI_SDK_PATH Condition="'$(WASI_SDK_PATH)' == ''">/opt/wasi-sdk</WASI_SDK_PATH>
    <SelfContained>true</SelfContained>
    <IlcExportUnmanagedEntrypoints>true</IlcExportUnmanagedEntrypoints>
    <NativeLib>Shared</NativeLib>
    <WasmEnableThreads>false</WasmEnableThreads>
    <MSBuildEnableWorkloadResolver>false</MSBuildEnableWorkloadResolver>
    <RootNamespace>SekibanDcbDecider.Wasm</RootNamespace>
    <AssemblyName>SekibanDcbDecider.Wasm</AssemblyName>
    <!-- Self-contained like an external consumer (versions pinned here, not via CPM). -->
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <!-- IDE/local restore does not use NuGet.wasm.config, so add the ILCompiler feeds here. -->
    <RestoreAdditionalProjectSources
      Condition="'$(RestoreConfigFile)' == ''">https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet10/nuget/v3/index.json;https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-experimental/nuget/v3/index.json</RestoreAdditionalProjectSources>
  </PropertyGroup>

  <!-- WASM reactor ABI exported to the runtime host (1.0.0-preview.3 contract). -->
  <ItemGroup>
    <LinkerArg Include="-mexec-model=reactor" />
    <LinkerArg Include="-Wl,--export,_initialize" />
    <LinkerArg Include="-Wl,--export,alloc" />
    <LinkerArg Include="-Wl,--export,dealloc" />
    <LinkerArg Include="-Wl,--export,create_instance" />
    <LinkerArg Include="-Wl,--export,apply_event" />
    <LinkerArg Include="-Wl,--export,apply_events_batch" />
    <LinkerArg Include="-Wl,--export,execute_query" />
    <LinkerArg Include="-Wl,--export,execute_list_query" />
    <LinkerArg Include="-Wl,--export,serialize_state" />
    <LinkerArg Include="-Wl,--export,restore_state" />
    <!-- Materialized View ABI (mv_host_query_rows is auto-emitted as an `env` import). -->
    <LinkerArg Include="-Wl,--export,mv_metadata" />
    <LinkerArg Include="-Wl,--export,mv_initialize" />
    <LinkerArg Include="-Wl,--export,mv_apply_event" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.DotNet.ILCompiler.LLVM" Version="10.0.0-*" />
    <PackageReference Include="ResultBoxes" Version="0.4.0" />
    <PackageReference Include="runtime.linux-x64.microsoft.dotnet.ilcompiler.llvm" Version="10.0.0-*" />
    <PackageReference Include="runtime.osx-arm64.microsoft.dotnet.ilcompiler.llvm"
                      Version="10.0.0-*"
                      Condition="'$(EnableMacIlCompilerRuntime)' == 'true'" />
  </ItemGroup>

  <ItemGroup>
    <!-- Sample-internal project reference (the domain compiled into this WASM module). -->
    <ProjectReference Include="..\SekibanDcbDecider.Domain\SekibanDcbDecider.Domain.csproj" />
  </ItemGroup>
</Project>
